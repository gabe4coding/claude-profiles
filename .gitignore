# Local builds (anchored to repo root so the claude-profiles/ fixture dir is unaffected)
/claude-profiles
/cmd/claude-profiles/claude-profiles
*.test

# Claude Code local state: worktrees, project-level settings, plugin state.
# Each .claude/worktrees/<name>/ is its own git tree; ignoring at the repo
# root prevents `git add -A` from staging them as embedded submodules.
/.claude/

# macOS
.DS_Store

# KB curator runtime state and auto-generated indexes.
# Inbox is the ephemeral event queue (state file + processed/ events that already
# fed durable entries). INDEX.md files are regenerated by the kb-index.sh Stop
# hook on every curator turn — tracking them adds diff noise without value.
/.kb/inbox/
/.kb/INDEX.md
/.kb/INDEX-by-tag.md
/.kb/*/INDEX.md
